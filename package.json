{
	"name": "bloom",
	"version": "0.1.0",
	"description": "Bloom — Pi-native OS platform on Fedora bootc",
	"type": "module",
	"private": true,
	"engines": {
		"node": ">=22"
	},
	"keywords": [
		"pi-package"
	],
	"pi": {
		"extensions": [
			"./core/extensions",
			"./extensions"
		]
	},
	"peerDependencies": {
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@sinclair/typebox": "*"
	},
	"dependencies": {
		"hosted-git-info": "^9.0.2",
		"js-yaml": "^4.1.0",
		"matrix-bot-sdk": "^0.8.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@mariozechner/pi-ai": "^0.57.1",
		"@mariozechner/pi-coding-agent": "^0.57.1",
		"@sinclair/typebox": "^0.34.0",
		"@types/hosted-git-info": "^3.0.5",
		"@types/js-yaml": "^4.0.9",
		"@vitest/coverage-v8": "^4.0.18",
		"typescript": "^5.7.0",
		"vitest": "^4.0.18"
	},
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"build": "rm -rf dist && tsc --build",
		"check": "biome check .",
		"check:fix": "biome check --write ."
	}
}
