# Source .bashrc for env vars (BLOOM_DIR, WAYLAND_DISPLAY, PATH, etc.)
[ -f ~/.bashrc ] && . ~/.bashrc

# Graphical mode: if on tty1 with a GPU, launch Sway desktop.
# This runs BEFORE the Pi session lock so serial console doesn't block it.
# Pi runs inside a foot terminal within Sway (see sway-config).
if [ -t 0 ] && [ "$(tty)" = "/dev/tty1" ] && [ -d /dev/dri ] && ls /dev/dri/card* >/dev/null 2>&1; then
  export WLR_RENDERER_ALLOW_SOFTWARE=1
  export XDG_SESSION_TYPE=wayland
  exec sway --config /etc/bloom/sway-config
fi

# Start Pi on interactive login (only one instance — atomic mkdir lock)
if [ -t 0 ] && [ -z "$PI_SESSION" ] && mkdir /tmp/.bloom-pi-session 2>/dev/null; then
  trap 'rmdir /tmp/.bloom-pi-session 2>/dev/null' EXIT
  export PI_SESSION=1
  /usr/local/bin/bloom-greeting.sh

  # CLI mode (serial console, SSH, or no GPU): start Pi directly
  # First boot: wait for local LLM and trigger setup wizard
  if [ ! -f "$HOME/.bloom/.setup-complete" ]; then
    spin='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    llm_ready=0
    printf '\n  Loading local AI model (Qwen3 4B)  '
    for i in $(seq 1 120); do
      printf '\b%s' "${spin:i%10:1}"
      if curl -sf http://127.0.0.1:8000/api/v1/health >/dev/null 2>&1; then
        llm_ready=1
        break
      fi
      sleep 1
    done
    if [ "$llm_ready" -eq 1 ]; then
      # Pull model if not already downloaded
      if ! curl -sf http://127.0.0.1:8000/api/v1/models 2>/dev/null | grep -q 'Qwen3-4B-GGUF'; then
        printf '\r  Downloading Qwen3 4B model (first boot, ~2.5 GB)  '
        curl -sf -N -X POST http://127.0.0.1:8000/api/v1/pull \
          -H 'Content-Type: application/json' \
          -d '{"model":"Qwen3-4B-GGUF","stream":true}' >/dev/null 2>&1 &
        pull_pid=$!
        for j in $(seq 1 600); do
          printf '\b%s' "${spin:j%10:1}"
          if curl -sf http://127.0.0.1:8000/api/v1/models 2>/dev/null | grep -q 'Qwen3-4B-GGUF'; then
            break
          fi
          if ! kill -0 "$pull_pid" 2>/dev/null; then
            curl -sf -N -X POST http://127.0.0.1:8000/api/v1/pull \
              -H 'Content-Type: application/json' \
              -d '{"model":"Qwen3-4B-GGUF","stream":true}' >/dev/null 2>&1 &
            pull_pid=$!
          fi
          sleep 1
        done
        kill "$pull_pid" 2>/dev/null || true
        wait "$pull_pid" 2>/dev/null || true
        printf '\n'
      fi
      printf '\r  Loading local AI model (Qwen3 4B)  ready!\n\n'
      exec pi --provider bloom-local --model Qwen3-4B-GGUF "hello"
    else
      printf '\r  Loading local AI model (Qwen3 4B)  timed out\n\n'
      printf '  LLM failed to start. Starting Pi without local model.\n'
      printf '  Run: systemctl --user status bloom-lemonade\n\n'
      exec pi
    fi
  else
    exec pi
  fi
fi
