# Bloom OS — Fedora bootc 42 with Pi coding agent
# Build: podman build -f os/Containerfile -t bloom-os:latest .
# Install: sudo bootc install to-disk /dev/sdX --source-imgref containers-storage:bloom-os:latest
FROM quay.io/fedora/fedora-bootc:42@sha256:88db1a4a445e904a40187fc23594500a0671a3b85bad7a4c8689ec3e30a8b96b

# System + development packages
RUN dnf install -y \
    sudo \
    git \
    git-lfs \
    gh \
    ripgrep \
    fd-find \
    jq \
    bat \
    htop \
    just \
    ShellCheck \
    openssl \
    openssh-clients \
    curl \
    wget \
    unzip \
    libatomic \
    podman \
    buildah \
    skopeo \
    oras \
    qemu-system-x86 \
    edk2-ovmf \
    sway \
    greetd \
    tuigreet \
    wayvnc \
    foot \
    xdg-desktop-portal-wlr \
    wl-clipboard \
    grim \
    slurp \
    nodejs \
    npm \
    && dnf clean all \
    && rm -rf /var/cache/libdnf5 /var/lib/dnf /var/log/dnf5.log /var/log/dnf.log /var/cache/ldconfig/aux-cache

# Install VS Code (Microsoft repo)
RUN rpm --import https://packages.microsoft.com/keys/microsoft.asc && \
    printf "[code]\nname=Visual Studio Code\nbaseurl=https://packages.microsoft.com/yumrepos/vscode\nenabled=1\ngpgcheck=1\ngpgkey=https://packages.microsoft.com/keys/microsoft.asc\n" > /etc/yum.repos.d/vscode.repo && \
    dnf install -y code && \
    dnf clean all && \
    rm -rf /var/cache/libdnf5 /var/lib/dnf /var/log/dnf5.log /var/log/dnf.log /var/cache/ldconfig/aux-cache

# Create bloom system user via systemd-sysusers
COPY os/sysconfig/bloom-sysusers.conf /usr/lib/sysusers.d/bloom.conf
RUN systemd-sysusers

# First-boot sudo access for the bloom user (non-interactive setup tasks).
COPY os/sysconfig/bloom-sudoers /etc/sudoers.d/10-bloom-firstboot
RUN chmod 0440 /etc/sudoers.d/10-bloom-firstboot

# Rootless Podman prerequisite: subordinate UID/GID ranges for user namespaces
RUN printf "bloom:100000:65536\n" >> /etc/subuid && \
    printf "bloom:100000:65536\n" >> /etc/subgid

ARG PI_CODING_AGENT_VERSION=0.55.4
ARG BIOME_VERSION=2.4.5
ARG TYPESCRIPT_VERSION=5.9.3
ARG CLAUDE_CODE_VERSION=2.1.69

# Install global CLI tooling (pinned versions; keep npm cache out of /var for bootc lint)
RUN HOME=/tmp npm install -g --cache /tmp/npm-cache \
    @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION} \
    @mariozechner/pi-coding-agent@${PI_CODING_AGENT_VERSION} \
    @biomejs/biome@${BIOME_VERSION} \
    typescript@${TYPESCRIPT_VERSION} \
    && rm -rf /tmp/npm-cache /var/roothome/.npm /root/.npm

# Install Bloom Pi package
COPY . /usr/local/share/bloom/
RUN cd /usr/local/share/bloom && HOME=/tmp npm install --omit=dev --cache /tmp/npm-cache && \
    rm -rf /tmp/npm-cache /var/roothome/.npm /root/.npm

# Configure Pi settings defaults in /usr (immutable layer)
RUN mkdir -p /usr/local/share/bloom/.pi/agent && \
    echo '{"packages": ["/usr/local/share/bloom"]}' > /usr/local/share/bloom/.pi/agent/settings.json

# Shell config skel in /usr (immutable layer)
COPY os/sysconfig/bloom-bashrc /usr/local/share/bloom/skel/.bashrc
COPY os/sysconfig/bloom-bash_profile /usr/local/share/bloom/skel/.bash_profile

# Minimal desktop defaults: greetd + sway + wayvnc
COPY os/sysconfig/greetd.toml /etc/greetd/config.toml
RUN mkdir -p /usr/local/share/bloom/skel/.config/sway
COPY os/sysconfig/sway-config /usr/local/share/bloom/skel/.config/sway/config

# tmpfiles.d for /var directory structure (created at boot)
COPY os/sysconfig/bloom-tmpfiles.conf /usr/lib/tmpfiles.d/bloom.conf

# Keep console output quiet so kernel/podman chatter does not overwrite Pi's TUI.
COPY os/sysconfig/bloom-sysctl.conf /usr/lib/sysctl.d/60-bloom-console.conf

# Default Quadlet network definition used by service packages
COPY os/sysconfig/bloom.network /usr/share/containers/systemd/bloom.network

# Install persona files
RUN mkdir -p /usr/local/share/bloom/persona

# Systemd service for Pi auto-start on login
COPY os/sysconfig/bloom-greeting.sh /usr/local/bin/bloom-greeting.sh
RUN chmod +x /usr/local/bin/bloom-greeting.sh

# Boot to desktop with greetd (sway is configured as default session)
RUN systemctl enable greetd.service
RUN systemctl set-default graphical.target

# Update check timer
COPY os/sysconfig/bloom-update-check.timer /usr/lib/systemd/system/bloom-update-check.timer
COPY os/sysconfig/bloom-update-check.service /usr/lib/systemd/system/bloom-update-check.service
COPY os/sysconfig/bloom-update-check.sh /usr/local/bin/bloom-update-check.sh
RUN chmod +x /usr/local/bin/bloom-update-check.sh
RUN systemctl enable bloom-update-check.timer

# bootc installation config
COPY os/bootc/config.toml /usr/lib/bootc/install/config.toml

# Labels
LABEL containers.bootc 1
LABEL com.github.containers.toolbox="false"
LABEL bloom.version="0.0.1"
LABEL description="Bloom — Pi-native AI companion OS"

# Validate bootc image (must be after all labels)
RUN bootc container lint
