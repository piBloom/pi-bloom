{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"rootDir": ".",
		"declaration": true,
		"composite": true,
		"sourceMap": true
	},
	"include": ["core/**/*.ts", "tests/**/*.ts"],
	"exclude": ["node_modules", "dist", "core/chat-server/frontend"]
}
