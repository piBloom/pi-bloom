[Unit]
Description=NixPI Signal CLI Daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=@BASE@
Environment=PATH=/run/current-system/sw/bin
Environment=SIGNAL_GATEWAY_STATE_DIR=@STATE_DIR@
Environment=SIGNAL_GATEWAY_CONFIG=@CONFIG@
ExecStart=@BASE@/bin/start-signal-daemon
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
