#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${SIGNAL_GATEWAY_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/nixpi-signal-gateway}"
PIDFILE="$STATE_DIR/tmp/signal-daemon.pid"

if [ ! -f "$PIDFILE" ]; then
  echo "signal daemon is not running"
  exit 0
fi

PID=$(cat "$PIDFILE" || true)
if [ -n "${PID:-}" ] && kill -0 "$PID" 2>/dev/null; then
  kill "$PID" || true
  sleep 2
  if kill -0 "$PID" 2>/dev/null; then
    kill -9 "$PID" || true
  fi
fi

rm -f "$PIDFILE"
echo "signal daemon stopped"
