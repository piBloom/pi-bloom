{
	"$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
	"formatter": {
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 120
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	},
	"linter": {
		"rules": {
			"recommended": true
		}
	},
	"files": {
		"includes": [
			"**",
			"!node_modules",
			"!dist",
			"!services/whatsapp/node_modules",
			"!.worktrees",
			"!os/output",
			"!.pi",
			"!.claude",
			"!coverage"
		]
	}
}
